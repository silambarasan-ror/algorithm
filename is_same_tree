def is_same_tree(p, q)
    return false unless tree_traversal(p,q)
    return true
end

def tree_traversal(p,q)
    return true if p.nil? && q.nil?
    return false if (p&.val != q&.val)
    left = tree_traversal(p&.left, q&.left)
    right = tree_traversal(p&.right, q&.right)
    left && right
end
